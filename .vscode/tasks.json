{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "npm: compile",
			"type": "shell",
			"command": "npm",
			"args": ["run", "compile"],
			"problemMatcher": "$tsc",
			"windows": {
				"options": {
					"shell": {
						"executable": "cmd.exe",
						"args": ["/d", "/s", "/c"]
					}
				}
			}
		},
		{
			"label": "npm: watch",
			"type": "shell",
			"command": "npm",
			"args": ["run", "watch"],
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"windows": {
				"options": {
					"shell": {
						"executable": "cmd.exe",
						"args": ["/d", "/s", "/c"]
					}
				}
			}
		}
	]
}
